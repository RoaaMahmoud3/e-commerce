{
  "version": 3,
  "framework": "angular",
  "buildCommand": "npm run build:ssr",
  "installCommand": "npm install",
  "outputDirectory": "dist/fresh-card/browser",
  "functions": {
    "api/server.js": {
      "runtime": "nodejs20.x",
      "handler": "dist/fresh-card/server/server.mjs"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/server.js" }
  ]
}

